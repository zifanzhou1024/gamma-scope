{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gammascope.local/schemas/common.schema.json",
  "title": "GammaScope Common Contract Types",
  "type": "object",
  "$defs": {
    "IsoDateTime": {
      "type": "string",
      "format": "date-time"
    },
    "OptionRight": {
      "type": "string",
      "enum": ["call", "put"]
    },
    "QuoteStatus": {
      "type": "string",
      "enum": ["valid", "stale", "missing", "crossed", "invalid"]
    },
    "CalcStatus": {
      "type": "string",
      "enum": [
        "ok",
        "missing_quote",
        "invalid_quote",
        "below_intrinsic",
        "vol_out_of_bounds",
        "stale_underlying",
        "solver_failed",
        "out_of_model_scope"
      ]
    },
    "ComparisonStatus": {
      "type": "string",
      "enum": ["ok", "missing", "stale", "outside_tolerance", "not_supported"]
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gammascope.local/schemas/experimental-flow.schema.json",
  "title": "ExperimentalFlow",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "meta", "summary", "strikeRows", "contractRows", "replayValidation", "diagnostics"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "meta": { "$ref": "#/$defs/Meta" },
    "summary": { "$ref": "#/$defs/Summary" },
    "strikeRows": { "type": "array", "items": { "$ref": "#/$defs/StrikeFlowRow" } },
    "contractRows": { "type": "array", "items": { "$ref": "#/$defs/ContractFlowRow" } },
    "replayValidation": { "oneOf": [{ "$ref": "#/$defs/ReplayValidation" }, { "type": "null" }] },
    "diagnostics": { "type": "array", "items": { "$ref": "#/$defs/Diagnostic" } }
  },
  "$defs": {
    "Mode": { "type": "string", "enum": ["latest", "replay"] },
    "Confidence": { "type": "string", "enum": ["high", "medium", "low", "unknown"] },
    "Aggressor": { "type": "string", "enum": ["buy", "weak_buy", "sell", "weak_sell", "unknown"] },
    "Right": { "type": "string", "enum": ["call", "put"] },
    "Severity": { "type": "string", "enum": ["info", "warning", "error"] },
    "HitClassification": { "type": "string", "enum": ["hit", "miss", "flat", "unknown"] },
    "Meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "symbol", "expiry", "generatedAt", "sourceSessionId", "currentSnapshotTime", "previousSnapshotTime"],
      "properties": {
        "mode": { "$ref": "#/$defs/Mode" },
        "symbol": { "type": "string", "const": "SPX" },
        "expiry": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "generatedAt": { "type": "string", "format": "date-time" },
        "sourceSessionId": { "type": "string", "minLength": 1 },
        "currentSnapshotTime": { "type": "string", "format": "date-time" },
        "previousSnapshotTime": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "Summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["estimatedBuyContracts", "estimatedSellContracts", "netEstimatedContracts", "netPremiumFlow", "netDeltaFlow", "netGammaFlow", "estimatedDealerGammaPressure", "confidence"],
      "properties": {
        "estimatedBuyContracts": { "type": "number", "minimum": 0 },
        "estimatedSellContracts": { "type": "number", "minimum": 0 },
        "netEstimatedContracts": { "type": "number" },
        "netPremiumFlow": { "type": "number" },
        "netDeltaFlow": { "type": ["number", "null"] },
        "netGammaFlow": { "type": ["number", "null"] },
        "estimatedDealerGammaPressure": { "type": ["number", "null"] },
        "confidence": { "$ref": "#/$defs/Confidence" }
      }
    },
    "StrikeFlowRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strike", "callBuyContracts", "callSellContracts", "putBuyContracts", "putSellContracts", "netPremiumFlow", "netDeltaFlow", "netGammaFlow", "estimatedDealerGammaPressure", "openingScore", "closingScore", "confidence", "tags"],
      "properties": {
        "strike": { "type": "number", "exclusiveMinimum": 0 },
        "callBuyContracts": { "type": "number", "minimum": 0 },
        "callSellContracts": { "type": "number", "minimum": 0 },
        "putBuyContracts": { "type": "number", "minimum": 0 },
        "putSellContracts": { "type": "number", "minimum": 0 },
        "netPremiumFlow": { "type": "number" },
        "netDeltaFlow": { "type": ["number", "null"] },
        "netGammaFlow": { "type": ["number", "null"] },
        "estimatedDealerGammaPressure": { "type": ["number", "null"] },
        "openingScore": { "type": "number", "minimum": 0, "maximum": 1 },
        "closingScore": { "type": "number", "minimum": 0, "maximum": 1 },
        "confidence": { "$ref": "#/$defs/Confidence" },
        "tags": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "ContractFlowRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractId", "right", "strike", "volumeDelta", "aggressor", "signedContracts", "premiumFlow", "deltaFlow", "gammaFlow", "vannaFlow", "thetaFlow", "openingScore", "closingScore", "confidence", "diagnostics"],
      "properties": {
        "contractId": { "type": "string", "minLength": 1 },
        "right": { "$ref": "#/$defs/Right" },
        "strike": { "type": "number", "exclusiveMinimum": 0 },
        "volumeDelta": { "type": "number", "minimum": 0 },
        "aggressor": { "$ref": "#/$defs/Aggressor" },
        "signedContracts": { "type": "number" },
        "premiumFlow": { "type": "number" },
        "deltaFlow": { "type": ["number", "null"] },
        "gammaFlow": { "type": ["number", "null"] },
        "vannaFlow": { "type": ["number", "null"] },
        "thetaFlow": { "type": ["number", "null"] },
        "openingScore": { "type": "number", "minimum": 0, "maximum": 1 },
        "closingScore": { "type": "number", "minimum": 0, "maximum": 1 },
        "confidence": { "$ref": "#/$defs/Confidence" },
        "diagnostics": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "ReplayValidation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["horizonMinutes", "rows", "hitRate"],
      "properties": {
        "horizonMinutes": { "type": "integer", "enum": [5, 15, 30] },
        "rows": { "type": "array", "items": { "$ref": "#/$defs/ReplayValidationRow" } },
        "hitRate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
      }
    },
    "ReplayValidationRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshotTime", "pressureDirection", "pressureMagnitude", "currentSpot", "futureSpot", "realizedMove", "classification"],
      "properties": {
        "snapshotTime": { "type": "string", "format": "date-time" },
        "pressureDirection": { "type": "string", "enum": ["positive", "negative", "flat", "unknown"] },
        "pressureMagnitude": { "type": ["number", "null"] },
        "currentSpot": { "type": "number", "exclusiveMinimum": 0 },
        "futureSpot": { "oneOf": [{ "type": "number", "exclusiveMinimum": 0 }, { "type": "null" }] },
        "realizedMove": { "type": ["number", "null"] },
        "classification": { "$ref": "#/$defs/HitClassification" }
      }
    },
    "Diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "severity"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "severity": { "$ref": "#/$defs/Severity" }
      }
    }
  }
}
